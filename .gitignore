cat > .gitignore << 'EOF'
# Virtual Environment
venv/
env/
ENV/

# Django
*.sqlite3
*.log
local_settings.py
db.sqlite3-journal
/media
/staticfiles
/static

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
*.egg
MANIFEST

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# OS
Thumbs.db
EOF